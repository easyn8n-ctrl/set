# === REQUIRED ===
# PostgreSQL connection string (Neon.tech recommended)
DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# Secret key for JWT tokens and admin auth (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=your-secret-key-here

# === STRIPE PAYMENTS ===
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# === OPTIONAL ===
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Admin seed key (used once to create initial admin account)
ADMIN_SEED_KEY=your-seed-key-here
